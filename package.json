{
  "name": "toon-meta",
  "version": "0.0.0",
  "private": true,
  "description": "TOON Protocol docs/tracker repo — hosts the sandcastle docs factory and its doc-lint gate. Not a publishable package; exists only to carry devDeps + scripts.",
  "type": "module",
  "scripts": {
    "lint:md": "markdownlint-cli2",
    "check:links": "node scripts/factory/check-links.mjs",
    "validate:json": "node scripts/factory/validate-json.mjs",
    "gate": "npm run lint:md && npm run check:links && npm run validate:json",
    "sandcastle": "npx tsx .sandcastle/main.ts",
    "sandcastle:plan": "npx tsx .sandcastle/plan-dry-run.ts",
    "sandcastle:implement": "npx tsx .sandcastle/agent-implement-issue.ts",
    "sandcastle:review": "npx tsx .sandcastle/agent-review-pr.ts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "0.12.0",
    "ajv": "^8.17.1",
    "markdown-link-check": "^3.13.7",
    "markdownlint-cli2": "^0.18.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  }
}

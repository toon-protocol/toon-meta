{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toon-protocol.dev/schemas/evals.schema.json",
  "title": "Skill eval suite",
  "description": "Shape of skills/<skill>/evals/evals.json — a trigger-eval + output-eval suite used by the skill-eval framework. Lenient: extra keys are allowed so the schema guards structure without over-constraining.",
  "type": "object",
  "required": ["trigger_evals", "output_evals"],
  "properties": {
    "trigger_evals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query", "should_trigger"],
        "properties": {
          "query": { "type": "string", "minLength": 1 },
          "should_trigger": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "output_evals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "prompt": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
